{
  "name": "@tokengate/cli",
  "version": "0.2.0",
  "description": "End-to-end encrypted environment variable sync",
  "type": "module",
  "bin": {
    "tokengate": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "check": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@tokengate/crypto": "workspace:*",
    "@tokengate/env-format": "workspace:*",
    "@tokengate/sdk": "workspace:*",
    "@clack/prompts": "^1.1.0",
    "picocolors": "^1.1.1"
  },
  "keywords": [
    "env",
    "environment",
    "secrets",
    "encryption",
    "e2e",
    "sync",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Snowy7/tokengate.git",
    "directory": "apps/cli"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
