{
  "name": "tokengate-dev",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --cwd apps/web dev",
    "dev:cli": "bun --cwd apps/cli dev",
    "dev:convex": "bunx convex dev",
    "build:web": "bun --cwd apps/web build",
    "test": "bun test",
    "typecheck": "bun --filter '*' x tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.9.3"
  }
}
