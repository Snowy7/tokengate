{
  "name": "tokengate-dev",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    ".",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "dotenv -e .env.local -- bunx convex dev --env-file .env.local",
    "dev:all": "turbo run dev --parallel --filter=tokengate-dev --filter=@tokengate/web",
    "dev:web": "turbo run dev --filter=@tokengate/web --",
    "dev:cli": "bun --cwd apps/cli dev",
    "dev:convex": "bun run dev",
    "build:web": "turbo run build --filter=@tokengate/web",
    "check:cli": "turbo run check --filter=@tokengate/cli",
    "check:web": "turbo run check --filter=@tokengate/web",
    "verify": "bun test packages && turbo run check --filter=@tokengate/cli --filter=@tokengate/web",
    "test": "bun test",
    "typecheck": "bun --filter '*' x tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "convex": "^1.18.2",
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
